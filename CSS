body {
  font-family: Arial, sans-serif;
  margin: 0;
  padding: 0;
}
header {
  background: #2c3e50;
  color: white;
  padding: 15px;
  text-align: center;
}
nav a {
  color: white;
  margin: 0 10px;
  text-decoration: none;
}
form {
  display: flex;
  flex-direction: column;
  max-width: 400px;
  margin: auto;
}
form input, form button {
  margin: 5px 0;
  padding: 10px;
}
#eventList {
  list-style: none;
  padding: 0;
}
#eventList li {
  background: #ecf0f1;
  margin: 5px 0;
  padding: 10px;
}
